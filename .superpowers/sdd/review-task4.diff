+export interface Conversion {
+  from: RegExp;
+  to: string;
+  reason: string;
+}
+
+// Ported from neis-behavior-log SKILL.md §6.5 표현 변환 사전.
+export const CONVERSIONS: Conversion[] = [
+  { from: /교육활동 침해행위에 해당함/g, to: '교육활동 침해 소지가 있는 발언임', reason: '법률 단정 → 소지 표현으로 전환' },
+  { from: /모욕죄\s*성립|형법\s*제311조\s*모욕죄에\s*해당함/g, to: '교사 대상 모욕성 발언', reason: '형법 단정 → 묘사 표현으로 전환' },
+  { from: /공연성\s*(충족|성립)/g, to: '다른 학생들이 있는 상황에서 발언함', reason: '형법 구성요건 판단 → 관찰 사실로 전환' },
+  { from: /형사처벌\s*가능\s*사안|형법상\s*처벌\s*대상/g, to: '', reason: '형사 판단은 본문에서 삭제 (필요 시 교사 보관 메모)' },
+  { from: /아동학대에\s*해당함/g, to: '아동학대범죄의 처벌 등에 관한 특례법 제2조에 해당할 가능성이 있는 정황을 인지함', reason: '학대 단정 → 정황 인지 표현으로 전환' },
+  { from: /명예훼손에\s*해당함/g, to: '제3자 면전에서 모욕성 발언이 이루어진 상황임', reason: '명예훼손 단정 → 상황 묘사로 전환' },
+  { from: /교권보호위\s*회부\s*확정/g, to: '재발 여부에 따라 교권보호위원회 회부를 검토함', reason: '확정 단정 → 검토 표현으로 전환' },
+  { from: /학교폭력에\s*해당함/g, to: '학교폭력예방 및 대책에 관한 법률에 따른 사안조사가 필요한 정황을 인지함', reason: '학폭 단정 → 정황 인지 표현으로 전환' },
+  { from: /본 기록은\s*즉시\s*핵심\s*증거임|법적\s*효력이\s*강함|확정적\s*증거자료임/g, to: '', reason: '자기 평가 문장 삭제' },
+  { from: /교사가\s*옳게\s*대응함|교사\s*잘못\s*없음/g, to: '', reason: '자기 평가 문장 삭제 (옳고 그름은 사실에서 도출)' },
+];
+
+export function scanProhibited(text: string): { matched: string; reason: string }[] {
+  const hits: { matched: string; reason: string }[] = [];
+  for (const c of CONVERSIONS) {
+    const re = new RegExp(c.from.source, c.from.flags);
+    const m = text.match(re);
+    if (m) hits.push({ matched: m[0], reason: c.reason });
+  }
+  return hits;
+}
+
+export function applyConversions(text: string): { text: string; notes: string[] } {
+  let out = text;
+  const notes: string[] = [];
+  for (const c of CONVERSIONS) {
+    const re = new RegExp(c.from.source, c.from.flags);
+    if (re.test(out)) {
+      out = out.replace(new RegExp(c.from.source, c.from.flags), c.to);
+      notes.push(`'${c.reason}' 규칙으로 표현을 자동 조정했습니다.`);
+    }
+  }
+  // Collapse any double spaces left by deletions.
+  out = out.replace(/\s{2,}/g, ' ').replace(/\s+\./g, '.').trim();
+  return { text: out, notes };
+}
